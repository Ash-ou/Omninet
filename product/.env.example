# ──────────────────────────────────────────────
# Omninet — Variables d'environnement
# ──────────────────────────────────────────────
# Copier ce fichier en .env et adapter les valeurs.
# NE JAMAIS commiter de .env avec des secrets réels.
# ──────────────────────────────────────────────

# Application
OMNINET_APP_NAME=Omninet
OMNINET_APP_VERSION=0.1.0
OMNINET_DEBUG=false

# JWT / Auth
OMNINET_SECRET_KEY=change-me-in-production
OMNINET_ALGORITHM=HS256
OMNINET_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Auth agent (sécurité: obligatoire hors debug, ne pas garder la valeur par défaut)
# Utilisé par les endpoints pour s'authentifier auprès du SOC (header X-Agent-Token)
OMNINET_AGENT_TOKEN=change-me-agent-token

# Utilisateurs par défaut (MVP uniquement)
# Ces credentials sont utilisés par le simulateur d'attaques (container attacker)
# pour obtenir un token JWT et envoyer des événements
OMNINET_ADMIN_USERNAME=admin
OMNINET_ADMIN_PASSWORD=admin
OMNINET_ANALYST_USERNAME=analyst
OMNINET_ANALYST_PASSWORD=analyst
